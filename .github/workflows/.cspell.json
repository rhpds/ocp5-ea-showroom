  "ignoreWords": [
    "adoc",
    "xref",
    "ifndef",
    "endif",
    "ifdef",
    "asciidoc",
    "TODO",
    "FIXME",
    "rhdp",
    "roxctl",
    "stackrox"
  ],
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "*.min.js",
    "*.min.css",
    "www/**"
  ],
  "overrides": [
    {
      "filename": "**/*.adoc",
      "ignoreRegExpList": [
        "/^\\s*----[\\s\\S]*?^\\s*----\\s*$/gm",
        "/^\\s*\\+\\+\\+\\+[\\s\\S]*?^\\s*\\+\\+\\+\\+\\s*$/gm",
        "\\[source,.*\\]",
        "\\[.*,role=.*\\]",
        "\\+\\+\\+.*\\+\\+\\+",
        "^\\[.*\\]$",
        "`[^`]*`",
        "^\\|.*\\|$",
        "^====+$",
        "^----+$",
        "^\\.\\.\\.\\.+$",
        "^\\*\\*\\*\\*+$",
        "^<.*>$",
        "xref:.*\\[.*\\]",
        "image::.*\\[.*\\]",
        "image:.*\\[.*\\]",
        "include::.*\\[.*\\]",
        "link:.*\\[.*\\]",
        "ifdef::.*\\[\\]",
        "ifndef::.*\\[\\]",
        "endif::.*\\[\\]",
        "^:.*:.*$"
      ]
    }
  ],
  "dictionaries": [
    "softwareTerms",
    "node",
    "typescript",
    "html",
    "css",
    "bash",
    "powershell"
  ]
